# The Vitest test stack (vitest@4 + @angular/build) has peer ranges that
# conflict with this project's pinned legacy deps (@types/node@16 via
# angular-playground's old jest tooling). npm's strict peer resolution rejects
# the install; legacy peer behavior resolves the tree the way it already builds.
# Required so a plain `npm install` (e.g. the AppHost common-ui-dev watch step)
# succeeds without a --legacy-peer-deps flag.
legacy-peer-deps=true
